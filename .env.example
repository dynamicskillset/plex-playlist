# Plex server URL (accessible from the container)
# If running on the same host as Plex, use host.docker.internal
PLEX_URL=http://host.docker.internal:32400

# Optional: seed initial config from environment rather than first-run UI
# PLEX_TOKEN=your_plex_token_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_api_key_here
# LLM_MODEL=gpt-4o
# LLM_CONTEXT_WINDOW=128000
